# ═══════════════════════════════════════════════════════════════
# Variables de entorno para Raspberry Pi Gateway (~/iot-gateway/.env)
# ═══════════════════════════════════════════════════════════════
# Este archivo documenta las variables que debe tener el .env REAL
# en la Raspberry Pi. NUNCA subir el .env real al repositorio.

# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- Gemini (AIRA) ---
GEMINI_API_KEY=tu_gemini_api_key

# --- Ubidots MQTT Cloud ---
UBIDOTS_MQTT_ENABLED=true
UBIDOTS_MQTT_HOST=industrial.api.ubidots.com
UBIDOTS_MQTT_PORT=1883
UBIDOTS_TOKEN=tu_token_de_ubidots
UBIDOTS_DEVICE_LABEL=aira-chia-nodo1
