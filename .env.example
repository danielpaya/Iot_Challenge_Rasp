# ═══════════════════════════════════════════════════════════════
# Variables PÚBLICAS para el frontend (GitHub Pages / navegador)
# ═══════════════════════════════════════════════════════════════
# Estas variables son visibles en el navegador.
# NO incluir tokens secretos, service role keys, ni API keys aquí.

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu_publishable_key

# URL pública del dashboard embebible de Ubidots (no requiere token)
UBIDOTS_PUBLIC_DASHBOARD_URL=https://industrial.ubidots.com/...

# Label del dispositivo en Ubidots (solo informativo)
UBIDOTS_DEVICE_LABEL=aira-chia-nodo1

# ID público del dispositivo (pegar si se necesita para embeber)
UBIDOTS_DEVICE_ID=https://stem.ubidots.com/app/devices/6a089f2708440c9defe89cd5

# ═══════════════════════════════════════════════════════════════
# NUNCA poner aquí:
#   - UBIDOTS_TOKEN
#   - GEMINI_API_KEY
#   - SUPABASE_SERVICE_ROLE_KEY
#
# Esos valores viven solo en la Raspberry Pi (~/iot-gateway/.env)
# ═══════════════════════════════════════════════════════════════
